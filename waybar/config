{
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 0,

  "margin-top": 15,
  "margin-bottom": 0,
  "margin-left": 250,
  "margin-right": 250,

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "custom/applauncher"
  ],

  "modules-right": [
    "network",
    "pulseaudio",
    "battery",
    "tray",
    "clock"
  ],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },

  "custom/applauncher": {
    "format": "",
    "tooltip": false,
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun"
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  },

  "clock": {
    "format": "󰅐 {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "interval": 1
  },

  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "󰈀 Ethernet",
    "format-disconnected": "󰤮 Offline",
    "tooltip": false
  },

  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟",
    "format-icons": [
      "",
      "",
      ""
    ],
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },

    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-full": "󱈑 {capacity}%",
    "format-icons": [
      "󱊡",
      "󱊢",
      "󱊣"
    ]
  }
}
